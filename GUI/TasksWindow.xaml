<Window x:Class="GUI.TasksWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="המשימות שלי" Height="600" Width="700" WindowStartupLocation="CenterScreen" Background="#F4F6F9" Loaded="Window_Loaded">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Button x:Name="btnBack" Content="חזרה" HorizontalAlignment="Left" Background="#7f8c8d" Click="btnBack_Click" Padding="15,5"/>
            <TextBlock Text="המשימות והמטלות שלי" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <DataGrid x:Name="dgTasks" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" FlowDirection="RightToLeft" SelectionChanged="dgTasks_SelectionChanged">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="בוצע" Binding="{Binding Is_done}" Width="50"/>
                <DataGridTextColumn Header="מקצוע" Binding="{Binding Subject_id.Subject_name}" Width="100"/>
                <DataGridTextColumn Header="כותרת המשימה" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="תאריך יעד" Binding="{Binding DueDate, StringFormat=d}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <StackPanel FlowDirection="RightToLeft">
                <TextBlock Text="הוספת משימה חדשה:" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="כותרת:"/>
                        <TextBox x:Name="txtTitle"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="מקצוע:"/>
                        <ComboBox x:Name="cmbSubject" DisplayMemberPath="Subject_name" SelectedValuePath="Id" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="תאריך יעד:"/>
                        <DatePicker x:Name="dpDueDate" Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button x:Name="btnAdd" Content="הוסף משימה" Background="{DynamicResource PrimaryBrush}" Click="btnAdd_Click" Margin="0,0,5,0"/>
                        <Button x:Name="btnDone" Content="סמן כבוצע" Background="{DynamicResource PrimaryBrush}" Click="btnDone_Click" IsEnabled="False" Margin="0,0,5,0"/>
                        <Button x:Name="btnDelete" Content="מחק" Background="#E74C3C" Click="btnDelete_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="תיאור:" Margin="0,5,0,0"/>
                <TextBox x:Name="txtDescription" Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
