<Window x:Class="GUI.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="סטטיסטיקות" Height="400" Width="400" WindowStartupLocation="CenterScreen" Background="#F4F6F9" Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Button x:Name="btnBack" Content="חזרה" HorizontalAlignment="Left" Background="#7f8c8d" Click="btnBack_Click" Padding="15,5"/>
            <TextBlock Text="סטטיסטיקות משימות" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20">
            <StackPanel FlowDirection="RightToLeft">
                <!-- Streak -->
                <Border Background="#fcf3cf" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="רצף למידה:" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtStreak" Text="🔥 0 ימים" FontSize="24" FontWeight="Bold" Foreground="#f39c12" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Goal Progress -->
                <Border Background="#ebf5fb" CornerRadius="8" Padding="15">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="התקדמות ליעד היומי:" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Name="btnEditGoal" Content="ערוך יעד" Background="Transparent" Foreground="#3498db" BorderThickness="0" Margin="10,0,0,0" Cursor="Hand" Click="btnEditGoal_Click"/>
                        </StackPanel>
                        <ProgressBar x:Name="pbGoal" Height="20" Margin="0,10,0,5" Foreground="{DynamicResource PrimaryBrush}" Background="#d6eaf8"/>
                        <TextBlock x:Name="txtGoal" Text="0/0 משימות" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="txtXpLow" Text="my xp bar is low" HorizontalAlignment="Center" Foreground="#e74c3c" FontSize="12" Margin="0,5,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
