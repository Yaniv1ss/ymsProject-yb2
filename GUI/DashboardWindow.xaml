<Window x:Class="GUI.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="מסך ראשי - המערכת שלי" Height="600" Width="800" WindowStartupLocation="CenterScreen" Background="#F4F6F9" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="btnLogout" Content="התנתק" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#e74c3c" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Click="btnLogout_Click"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" FlowDirection="RightToLeft">
                    <TextBlock Text="🕒" Foreground="White" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtTime" Text="00:00:00" Foreground="White" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#f39c12" CornerRadius="5" Padding="10,5" Margin="20,0,0,0">
                        <TextBlock x:Name="txtStreak" Text="🔥 רצף: 0" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="txtWelcome" Text="שלום, אורח!" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" FlowDirection="RightToLeft"/>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Dashboard Button: Tasks -->
                <Button Grid.Column="1" Grid.Row="0" Margin="10" Background="White" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1.5" Click="btnTasks_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="המשימות שלי" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Dashboard Button: Schedule -->
                <Button Grid.Column="0" Grid.Row="0" Margin="10" Background="White" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1.5" Click="btnSchedule_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📅" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="מערכת שעות" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Dashboard Button: Exams -->
                <Button Grid.Column="1" Grid.Row="1" Margin="10" Background="White" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1.5" Click="btnExams_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🎓" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="המבחנים שלי" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Dashboard Button: Profile -->
                <Button Grid.Column="0" Grid.Row="1" Margin="10" Background="White" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1.5" Click="btnProfile_Click">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                        <TextBlock Text="הגדרות ויעדים" FontSize="18" FontWeight="SemiBold" Foreground="#34495E" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <!-- Dashboard Button: Stats & Grades -->
                <Button x:Name="btnStats" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="White" BorderBrush="#dfe6e9" BorderThickness="1" Margin="5" Click="btnStats_Click">
                    <StackPanel>
                        <TextBlock Text="📊" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#2ecc71"/>
                        <TextBlock Text="רצף ומשימות" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#2c3e50"/>
                    </StackPanel>
                </Button>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
