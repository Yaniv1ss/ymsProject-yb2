<Window x:Class="GUI.AdminDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="מסך מנהל מערכת" Height="600" Width="900" WindowStartupLocation="CenterScreen" Background="#F4F6F9" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,0">
            <Grid>
                <TextBlock Text="לוח בקרת מנהל (Admin)" Foreground="White" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" FlowDirection="RightToLeft"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="txtTime" Text="00:00:00" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,10,0"/>
                    <TextBlock Text="🕒" Foreground="White" FontSize="20" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="btnLogout" Content="התנתק וחזור" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#e74c3c" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Click="btnLogout_Click"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20" MinHeight="500">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Actions -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0" FlowDirection="RightToLeft">
                    <TextBlock Text="פעולות מנהל:" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2c3e50"/>
                    <Button x:Name="btnMakeAdmin" Content="הפוך למנהל" Background="#f39c12" Foreground="White" Height="40" Margin="0,0,0,10" Click="btnMakeAdmin_Click"/>
                    <Button x:Name="btnRemoveAdmin" Content="הסר מנהל" Background="#e74c3c" Foreground="White" Height="40" Margin="0,0,0,10" Click="btnRemoveAdmin_Click"/>
                    <Separator Margin="0,10"/>
                    <Button x:Name="btnDeleteUser" Content="מחיקת משתמש" Background="#c0392b" Foreground="White" Height="40" Margin="0,0,0,10" Click="btnDeleteUser_Click"/>
                    <Button x:Name="btnSaveUserChanges" Content="שמירת שינויים (עריכה)" Background="#27ae60" Foreground="White" Height="40" Margin="0,0,0,10" Click="btnSaveUserChanges_Click"/>
                    <Separator Margin="0,10"/>
                    <TextBlock x:Name="txtSelectedUser" Text="בחר משתמש..." Foreground="#7f8c8d" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Main Panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="300"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>

                    <!-- User List -->
                    <GroupBox Grid.Row="0" Header="רשימת משתמשים (לחיצה כפולה לעריכה)" Margin="0,0,0,10" FlowDirection="RightToLeft">
                        <DataGrid x:Name="dgUsers" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Background="White" SelectionChanged="dgUsers_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="מזהה" Binding="{Binding Id}" Width="50" IsReadOnly="True"/>
                                <DataGridTextColumn Header="שם משתמש" Binding="{Binding Username}" Width="*"/>
                                <DataGridTextColumn Header="אימייל" Binding="{Binding Email}" Width="*"/>
                                <DataGridTextColumn Header="יעד" Binding="{Binding Goal}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#dfe6e9"/>

                    <!-- Details Panel -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Schedules -->
                        <GroupBox Grid.Column="0" Header="מערכת שעות" Margin="5,0,5,0" FlowDirection="RightToLeft">
                            <DockPanel>
                                <Button x:Name="btnDeleteSchedule" Content="מחק שעה" DockPanel.Dock="Bottom" Background="#e74c3c" Foreground="White" Click="btnDeleteSchedule_Click" Margin="0,5,0,0"/>
                                <DataGrid x:Name="dgSchedules" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="יום" Binding="{Binding Day_of_the_week}" Width="60"/>
                                        <DataGridTextColumn Header="שעה" Binding="{Binding Hour}" Width="40"/>
                                        <DataGridTextColumn Header="מקצוע" Binding="{Binding Subject_id.Subject_name}" IsReadOnly="True" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <!-- Tasks -->
                        <GroupBox Grid.Column="1" Header="משימות" Margin="5,0,5,0" FlowDirection="RightToLeft">
                            <DockPanel>
                                <Button x:Name="btnDeleteTask" Content="מחק משימה" DockPanel.Dock="Bottom" Background="#e74c3c" Foreground="White" Click="btnDeleteTask_Click" Margin="0,5,0,0"/>
                                <DataGrid x:Name="dgTasks" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="כותרת" Binding="{Binding Title}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="בוצע" Binding="{Binding Is_done}" Width="50"/>
                                        <DataGridTextColumn Header="תאריך" Binding="{Binding DueDate, StringFormat=d}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>

                        <!-- Exams -->
                        <GroupBox Grid.Column="2" Header="מבחנים וציונים" Margin="5,0,5,0" FlowDirection="RightToLeft">
                            <DockPanel>
                                <Button x:Name="btnDeleteExam" Content="מחק מבחן" DockPanel.Dock="Bottom" Background="#e74c3c" Foreground="White" Click="btnDeleteExam_Click" Margin="0,5,0,0"/>
                                <DataGrid x:Name="dgExams" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="כותרת" Binding="{Binding Title}" Width="*"/>
                                        <DataGridTextColumn Header="ציון" Binding="{Binding Grade}" Width="50"/>
                                        <DataGridTextColumn Header="תאריך" Binding="{Binding Exam_date}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
