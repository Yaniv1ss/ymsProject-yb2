<Window x:Class="GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GUI"
        mc:Ignorable="d"
        Title="ניהול משתמשים - פרויקט בגרות" Height="450" Width="800" Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Side: Data -->
        <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,0,10,0" Background="White">
            <StackPanel Margin="10">
                <TextBlock Text="רשימת משתמשים במערכת" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" FlowDirection="RightToLeft"/>
                <DataGrid x:Name="UsersDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="330" FlowDirection="RightToLeft">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="מזהה" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="שם משתמש" Binding="{Binding Username}" Width="*"/>
                        <DataGridTextColumn Header="אימייל" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="יעד" Binding="{Binding Goal}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Right Side: Action Form -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Background="White" Padding="10">
            <StackPanel FlowDirection="RightToLeft">
                <TextBlock Text="הוספת משתמש חדש" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <TextBlock Text="שם משתמש:"/>
                <TextBox x:Name="txtUsername" Margin="0,0,0,10" Height="25"/>
                
                <TextBlock Text="סיסמה:"/>
                <TextBox x:Name="txtPassword" Margin="0,0,0,10" Height="25"/>
                
                <TextBlock Text="אימייל:"/>
                <TextBox x:Name="txtEmail" Margin="0,0,0,10" Height="25"/>
                
                <TextBlock Text="יעד (מספר ציון):"/>
                <TextBox x:Name="txtGoal" Margin="0,0,0,15" Height="25"/>
                
                <Button x:Name="btnAddUser" Content="הוסף משתמש" Height="30" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnAddUser_Click"/>
                
                <Button x:Name="btnRefresh" Content="רענן רשימה" Height="30" Margin="0,15,0,0" Click="btnRefresh_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
