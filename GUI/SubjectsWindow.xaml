<Window x:Class="GUI.SubjectsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ניהול מקצועות לימוד" Height="400" Width="400" WindowStartupLocation="CenterScreen" Background="#F4F6F9" Loaded="Window_Loaded">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ניהול מקצועות" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Right" Margin="0,0,0,15"/>

        <DataGrid x:Name="dgSubjects" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" FlowDirection="RightToLeft" SelectionChanged="dgSubjects_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="מזהה" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="שם המקצוע" Binding="{Binding Subject_name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <StackPanel FlowDirection="RightToLeft">
                <TextBlock Text="הוספת מקצוע חדש:" FontWeight="Bold" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="txtSubjectName" Grid.Column="0" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button x:Name="btnAdd" Content="הוסף" Background="{DynamicResource PrimaryBrush}" Click="btnAdd_Click" Width="70" Margin="0,0,5,0"/>
                        <Button x:Name="btnDelete" Content="מחק" Width="70" Background="#E74C3C" Click="btnDelete_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
